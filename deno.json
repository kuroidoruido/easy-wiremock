{
  "tasks": {
    "serve": "deno run --allow-net --allow-read --allow-env deno-deploy-router.ts"
  },
  "deploy": {
    "org": "kuroidoruido",
    "app": "easy-wiremock",
    "exclude": [
      ".github/",
      "node_modules/",
      "scripts/",
